# Get your API key at https://build.nvidia.com — free tier, no GPU needed
# Used for reranker + LLM only (embeddings run locally)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NVIDIA NIM models (rerank + LLM)
LLM_MODEL=meta/llama-3.1-70b-instruct
RERANK_MODEL=nvidia/llama-3.2-nv-rerankqa-1b-v2

# Local embedding model (downloaded from HuggingFace, runs on CPU)
EMBED_MODEL=intfloat/e5-large-v2
EMBED_DIM=1024

# Milvus — full standalone via Docker (see docker-compose.yml)
MILVUS_URI=http://localhost:19530
COLLECTION_NAME=opensansad

# Retrieval params
TOP_K=10
RERANK_TOP_N=4
